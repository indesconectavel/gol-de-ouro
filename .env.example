# Gol de Ouro Backend - Variáveis de Ambiente
# ===========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o arquivo .env no Git
# 
# ⚠️  IMPORTANTE: Todas as variáveis são OBRIGATÓRIAS exceto PORT

# 🗄️ BANCO DE DADOS (OBRIGATÓRIO)
# URL de conexão com PostgreSQL (Supabase)
# Formato: postgresql://usuario:senha@host:porta/banco?sslmode=require
DATABASE_URL=postgresql://seu_usuario:sua_senha@seu_host:5432/seu_banco?sslmode=require

# 🌐 SERVIDOR (OPCIONAL - tem valor padrão)
# Porta onde o servidor irá rodar
PORT=3000

# 🔐 SEGURANÇA (OBRIGATÓRIO)
# Chave secreta para assinatura de JWT (mínimo 32 caracteres)
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_caracteres

# Token de autenticação para rotas administrativas (mínimo 16 caracteres)
# Gere um token único: node -e "console.log(require('crypto').randomUUID())"
ADMIN_TOKEN=seu_token_admin_unico_aqui_minimo_16_caracteres

# 🌍 CORS (OPCIONAL - tem valor padrão)
# Origens permitidas para CORS, separadas por vírgula
# Inclua o domínio do seu frontend admin
CORS_ORIGINS=http://localhost:5174,https://seu-admin.vercel.app

# 🏷️ AMBIENTE (OPCIONAL - tem valor padrão)
# Ambiente de execução: development, staging, production, test
NODE_ENV=development

# ===========================================
# EXEMPLOS DE VALORES:
# 
# DATABASE_URL=postgresql://postgres:minhasenha@localhost:5432/goldeouro
# JWT_SECRET=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz567890
# ADMIN_TOKEN=meu-token-admin-super-secreto-123
# CORS_ORIGINS=http://localhost:3000,https://meuapp.vercel.app
# NODE_ENV=production
# 
# ===========================================
# VALIDAÇÕES AUTOMÁTICAS:
# 
# ✅ JWT_SECRET: mínimo 32 caracteres
# ✅ ADMIN_TOKEN: mínimo 16 caracteres  
# ✅ DATABASE_URL: formato PostgreSQL válido
# ✅ CORS_ORIGINS: formato de lista válida
# ✅ NODE_ENV: valores permitidos
# 
# ===========================================
# SEGURANÇA:
# 
# 💸 MERCADO PAGO — PIX IN (depósito) vs PIX OUT (Payouts)
# Use apps DIFERENTES no painel Suas integrações (doc: uma app por solução).
# MERCADOPAGO_DEPOSIT_ACCESS_TOKEN=APP_USR-...   # app Checkout — PIX IN
# MERCADOPAGO_PAYOUT_ACCESS_TOKEN=APP_USR-...    # app Payouts — transaction-intents
# MP_PAYOUT_APP_ID=                              # ID da app Payouts (painel)
# MP_PAYOUT_TEST_TOKEN=true                      # sandbox; false em produção
# MP_PAYOUT_ENFORCE_SIGNATURE=false              # true só após Integrations team registrar chave pública
# MP_PAYOUT_PRIVATE_KEY=                         # PEM Ed25519 (mpprivate.pem) — nunca commitar
# MP_PAYOUT_WEBHOOK_URL=https://.../webhooks/mercadopago
# Scripts: npm run payout:audit | payout:sandbox (ver docs/configuracoes/PAYOUTS-EXECUCAO-ONBOARDING-E-TESTES.md)

# 🏦 CELCOIN — provider financeiro alternativo (modo preparatório; desligado por padrão)
# PRIMARY_PSP=asaas                      # PSP primário arquitetural V1 (F4.3C) — default implícito
# ASAAS_PRODUCTION_ENABLED=false         # gate produção: false mantém Mercado Pago efetivo em NODE_ENV=production
#                                        # P1.0: true habilita crédito real via POST /webhooks/asaas → claimAndCreditApprovedPixDeposit
# PAYMENT_PROVIDER=                      # omitir = PRIMARY_PSP (dev) ou mercadopago (prod sem gate)
# PAYOUT_PROVIDER=                       # omitir = PRIMARY_PSP (dev) ou mercadopago (prod sem gate)
# PAYOUT_PROVIDER=mercadopago            # legado explícito / fallback arquitetural
# PAYOUT_PROVIDER=celcoin                # só após CELCOIN_ENABLED=true + credenciais sandbox
# PAYMENT_WEBHOOK_ENGINE_ENABLED=false   # F4.5 — false mantém handler legado inline no monólito
# ASAAS_CONTROLLED_CREDIT_ENABLED=false  # F4.6 — crédito wallet/ledger controlado (sandbox only)
# PAYMENT_WEBHOOK_CONTROLLED_CREDIT=0    # F4.6 — gate crédito controlado
# CONTROLLED_CREDIT_STORE=local          # F4.6 — Opção B store local (sem Supabase prod)
# ASAAS_E2E_WEBHOOK_PUBLIC_BASE=         # F4.7 — URL pública estável (ngrok) para webhook oficial
# ASAAS_WEBHOOK_TUNNEL_URL=              # F4.7 — alias tunnel público
# ASAAS_E2E_USE_SMEE=0                   # F4.7 — usar smee.io como relay (opcional)
# ASAAS_WEBHOOK_ENABLED=false
# ASAAS_WEBHOOK_STRICT_MODE=true
# ALLOW_ASAAS_SANDBOX_WEBHOOK=0
CELCOIN_ENABLED=false
CELCOIN_HTTP_ENABLED=false
CELCOIN_BASE_URL=
CELCOIN_CLIENT_ID=
CELCOIN_CLIENT_SECRET=
CELCOIN_MTLS_CERT_PATH=
CELCOIN_MTLS_KEY_PATH=
CELCOIN_WEBHOOK_SECRET=

# 🔒 NUNCA commite este arquivo com valores reais
# 🔒 Use variáveis de ambiente nas plataformas de deploy
# 🔒 Rotacione JWT_SECRET e ADMIN_TOKEN regularmente
# 🔒 Use HTTPS em produção
# 🔒 Monitore logs de acesso
