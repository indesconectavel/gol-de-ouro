# Gol de Ouro Backend - Variáveis de Ambiente
# ===========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o arquivo .env no Git
# 
# ⚠️  IMPORTANTE: Todas as variáveis são OBRIGATÓRIAS exceto PORT

# 🗄️ BANCO DE DADOS (OBRIGATÓRIO)
# URL de conexão com PostgreSQL (Supabase)
# Formato: postgresql://usuario:senha@host:porta/banco?sslmode=require
DATABASE_URL=postgresql://seu_usuario:sua_senha@seu_host:5432/seu_banco?sslmode=require

# 🌐 SERVIDOR (OPCIONAL - tem valor padrão)
# server-fly.js usa PORT ou, se omitido, 8080 por omissão.
# Alinhe com VITE_API_URL do admin (ex.: http://localhost:8080).
PORT=8080

# 🔐 SEGURANÇA (OBRIGATÓRIO)
# Chave secreta para assinatura de JWT (mínimo 32 caracteres)
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_caracteres

# Token de autenticação para rotas administrativas (mínimo 16 caracteres)
# Gere um token único: node -e "console.log(require('crypto').randomUUID())"
ADMIN_TOKEN=seu_token_admin_unico_aqui_minimo_16_caracteres

# 🌍 CORS (OPCIONAL - tem valor padrão)
# Origens permitidas para CORS, separadas por vírgula
# Inclua a origem do Vite do admin (porta padrão 5173) e previews/deploys
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,https://seu-admin.vercel.app

# 🏷️ AMBIENTE (OPCIONAL - tem valor padrão)
# Ambiente de execução: development, staging, production, test
NODE_ENV=development

# ===========================================
# EXEMPLOS DE VALORES:
# 
# DATABASE_URL=postgresql://postgres:minhasenha@localhost:5432/goldeouro
# JWT_SECRET=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz567890
# ADMIN_TOKEN=meu-token-admin-super-secreto-123
# CORS_ORIGINS=http://localhost:3000,https://meuapp.vercel.app
# NODE_ENV=production
# 
# ===========================================
# VALIDAÇÕES AUTOMÁTICAS:
# 
# ✅ JWT_SECRET: mínimo 32 caracteres
# ✅ ADMIN_TOKEN: mínimo 16 caracteres  
# ✅ DATABASE_URL: formato PostgreSQL válido
# ✅ CORS_ORIGINS: formato de lista válida
# ✅ NODE_ENV: valores permitidos
# 
# 💳 FINANCEIRO (OPCIONAL)
# false = não usar RPCs atómicas creditar_pix_aprovado_mp / solicitar_saque_pix_atomico (só JS legado)
# Omitir ou true = tentar RPC primeiro (requer SQL em database/rpc-financeiro-atomico-2026-03-28.sql aplicado no Supabase)
# FINANCE_ATOMIC_RPC=true
#
# Webhook Mercado Pago (produção): assinatura secreta do painel «Suas integrações» → Webhooks
# MERCADOPAGO_WEBHOOK_SECRET=
# Janela opcional para validar ts em x-signature (segundos; padrão 600)
# MP_WEBHOOK_TS_SKEW_SEC=600

# ===========================================
# SEGURANÇA:
# 
# 🔒 NUNCA commite este arquivo com valores reais
# 🔒 Use variáveis de ambiente nas plataformas de deploy
# 🔒 Rotacione JWT_SECRET e ADMIN_TOKEN regularmente
# 🔒 Use HTTPS em produção
# 🔒 Monitore logs de acesso
